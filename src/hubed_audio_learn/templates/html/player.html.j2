<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ topic }}</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
<style>
  :root { color-scheme: light dark; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; max-width: 760px; margin: 0 auto; padding: 16px; }
  header { position: sticky; top: 0; background: var(--bg, white); padding: 12px 0; border-bottom: 1px solid #ddd; z-index: 10; }
  audio { width: 100%; }
  h1 { font-size: 1.3em; margin: 12px 0 6px 0; }
  .slide { border: 1px solid #ccc; border-radius: 10px; padding: 20px; margin: 16px 0; transition: box-shadow .25s ease, transform .25s ease; cursor: pointer; }
  .slide.active { box-shadow: 0 0 0 3px #4a90e2 inset; transform: scale(1.01); }
  .slide .caption { color: #666; font-size: 0.9em; margin-top: 8px; }
  .slide .math { font-size: 1.3em; text-align: center; padding: 12px 0; }
  .slide .scenario { background: #f6f8fa; padding: 12px; border-radius: 6px; white-space: pre-wrap; }
  @media (prefers-color-scheme: dark) {
    body { background: #0d1117; color: #e6edf3; }
    header { background: #0d1117; border-color: #30363d; }
    .slide { border-color: #30363d; }
    .slide .scenario { background: #161b22; }
  }
</style>
</head>
<body>
<header>
  <audio id="player" controls preload="auto" src="{{ mp3_filename }}"></audio>
  <h1>{{ topic }}</h1>
</header>

<section id="slides">
{% for fig in figures %}
  <article class="slide" data-figure-id="{{ fig.id }}" data-first-start="{{ fig.first_start_seconds }}">
    {% if fig.kind == 'math-block' and fig.latex %}
      <div class="math" data-latex="{{ fig.latex | e }}"></div>
    {% elif fig.kind == 'scenario' and fig.body %}
      <div class="scenario">{{ fig.body }}</div>
    {% else %}
      <div class="body">{{ fig.body or '' }}</div>
    {% endif %}
    <div class="caption">{{ fig.caption }}</div>
  </article>
{% endfor %}
</section>

<script id="timing-data" type="application/json">{{ timing_json | safe }}</script>
<script id="markers-data" type="application/json">{{ markers_json | safe }}</script>

<script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script>
(function () {
  const player = document.getElementById('player');
  const timing = JSON.parse(document.getElementById('timing-data').textContent).turns;
  const markers = JSON.parse(document.getElementById('markers-data').textContent); // {turnIndex: figureId}
  const slides = Array.from(document.querySelectorAll('.slide'));
  const slideById = new Map(slides.map(s => [s.dataset.figureId, s]));

  // Render KaTeX for math figures
  slides.forEach(s => {
    const m = s.querySelector('.math');
    if (m && m.dataset.latex) {
      try { katex.render(m.dataset.latex, m, { throwOnError: false, displayMode: true }); } catch (e) {}
    }
  });

  function currentTurn(t) {
    let lo = 0, hi = timing.length - 1, ans = 0;
    while (lo <= hi) {
      const mid = (lo + hi) >> 1;
      if (timing[mid].start_seconds <= t) { ans = mid; lo = mid + 1; }
      else hi = mid - 1;
    }
    return ans;
  }

  let lastActive = null;
  player.addEventListener('timeupdate', () => {
    const turn = currentTurn(player.currentTime);
    const figId = markers[turn];
    const slide = figId ? slideById.get(figId) : null;
    if (slide !== lastActive) {
      if (lastActive) lastActive.classList.remove('active');
      if (slide) {
        slide.classList.add('active');
        slide.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      lastActive = slide;
    }
  });

  slides.forEach(s => s.addEventListener('click', () => {
    const start = parseFloat(s.dataset.firstStart || '0');
    player.currentTime = start;
    player.play();
  }));

  if (location.hash && location.hash.startsWith('#t=')) {
    const parts = location.hash.slice(3).split(':').map(Number);
    const secs = parts.length === 2 ? parts[0] * 60 + parts[1] : parts[0];
    if (!Number.isNaN(secs)) player.currentTime = secs;
  }
})();
</script>
</body>
</html>
