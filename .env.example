# Required for Phase 1
GEMINI_API_KEY=

# Defaults — override if needed
LLM_PROVIDER=claude
TTS_PROVIDER=gemini
OUTPUT_DIR=./output
WORK_DIR=./.work

# Host personas (TTS voice names from Gemini docs: Charon, Leda, Aoede, Puck, Kore, etc.)
HOST_A_NAME=Alex
HOST_A_VOICE=Charon
HOST_B_NAME=Sam
HOST_B_VOICE=Leda

# Gemini model selection
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Claude CLI invocation
CLAUDE_BIN=claude
CLAUDE_TIMEOUT_SECONDS=600

# Logging
LOG_LEVEL=INFO
